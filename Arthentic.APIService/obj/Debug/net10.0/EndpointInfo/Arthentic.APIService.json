                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArtistDto"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArtistDto"
